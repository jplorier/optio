# Database
DATABASE_URL=postgres://optio:optio_dev@localhost:5432/optio

# Redis
REDIS_URL=redis://localhost:6379

# Container Runtime: "docker" | "kubernetes"
OPTIO_RUNTIME=kubernetes

# Encryption key for secrets at rest (generate with: openssl rand -hex 32)
OPTIO_ENCRYPTION_KEY=change-me-in-production

# API server
API_PORT=4000
API_HOST=0.0.0.0

# Docker socket (for Docker runtime)
DOCKER_HOST=unix:///var/run/docker.sock

# Agent container image
OPTIO_AGENT_IMAGE=optio-agent:latest
